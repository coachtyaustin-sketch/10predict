# ============================================
# 10Predict Configuration
# ============================================

# Database
DATABASE_URL=postgresql+asyncpg://tenpredict:password@localhost:5432/tenpredict
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tenpredict123

# LLM - OpenAI (used for chain analysis + reports)
OPENAI_API_KEY=sk-...
OPENAI_MODEL_CHAIN=gpt-4o-mini
OPENAI_MODEL_AGENTS=gpt-4o-mini
OPENAI_MODEL_REPORTS=gpt-4o-mini

# Data Sources
FINNHUB_API_KEY=...
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=10predict/1.0

# Scheduling (Eastern Time)
CYCLE_PREMARKET_HOUR=6
CYCLE_MIDDAY_HOUR=12
CYCLE_AFTERHOURS_HOUR=17
TIMEZONE=US/Eastern

# Simulation
MAX_AGENTS_PER_SIMULATION=12
SIMULATION_ROUNDS=5
MAX_STOCKS_PER_CYCLE=8

# App
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO
